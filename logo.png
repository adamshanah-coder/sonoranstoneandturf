@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap');

:root{--dark:#10180f;--deep:#081007;--green:#263e25;--gold:#c99a4a;--gold2:#e3bf73;--cream:#f8f1e4;--white:#fffdf7;--muted:#6f766b;--shadow:0 28px 70px rgba(8,16,7,.25)}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:Inter,system-ui,sans-serif;color:var(--dark);background:var(--cream)}a{color:inherit}
.nav-shell{position:fixed;inset:0 0 auto;z-index:50;height:84px;display:flex;align-items:center;justify-content:space-between;padding:0 clamp(18px,4vw,70px);background:rgba(8,16,7,.82);backdrop-filter:blur(18px);color:var(--white);border-bottom:1px solid rgba(255,255,255,.08)}
.brand{display:flex;align-items:center;gap:14px;text-decoration:none;font-weight:900}.brand img{width:58px;height:58px;object-fit:contain}.brand span{letter-spacing:-.03em}
nav{display:flex;align-items:center;gap:24px;font-size:.76rem;font-weight:900;letter-spacing:.09em;text-transform:uppercase}nav a{text-decoration:none;opacity:.92}.nav-cta{background:var(--gold);color:var(--deep);padding:15px 21px}
.hero{min-height:900px;position:relative;display:flex;align-items:center;overflow:hidden;color:var(--white)}.hero-image{position:absolute;inset:0;background-image:url('/images/hero.jpg');background-size:cover;background-position:center;transform:scale(1.02)}.hero-shade{position:absolute;inset:0;background:linear-gradient(90deg,rgba(8,16,7,.9) 0%,rgba(8,16,7,.66) 44%,rgba(8,16,7,.22) 100%),linear-gradient(180deg,rgba(8,16,7,.08),rgba(8,16,7,.66))}
.hero-content{position:relative;z-index:2;max-width:860px;padding:140px clamp(22px,5vw,72px) 60px}.eyebrow{margin:0 0 18px;color:var(--gold2);text-transform:uppercase;letter-spacing:.17em;font-size:.77rem;font-weight:900}.center{text-align:center}
h1,h2{font-family:'Playfair Display',Georgia,serif;letter-spacing:-.055em;font-weight:800;margin:0 0 22px}h1{font-size:clamp(4.2rem,8vw,8.3rem);line-height:.88}h2{font-size:clamp(2.7rem,5vw,5.2rem);line-height:.95}h3,p{margin-top:0}.lead{max-width:620px;color:rgba(255,253,247,.84);font-size:1.18rem;line-height:1.75}
.hero-actions{display:flex;gap:16px;flex-wrap:wrap;margin:36px 0 28px}.button{min-height:58px;padding:0 28px;display:inline-flex;align-items:center;justify-content:center;border:0;text-decoration:none;text-transform:uppercase;letter-spacing:.08em;font-size:.82rem;font-weight:900;cursor:pointer}.gold{background:var(--gold);color:var(--deep);box-shadow:0 18px 45px rgba(201,154,74,.23)}.outline{border:1px solid rgba(255,255,255,.5);color:var(--white);background:rgba(255,255,255,.07)}
.hero-location{color:var(--gold2);font-weight:900;letter-spacing:.1em;text-transform:uppercase;font-size:.78rem}
.trust{display:grid;grid-template-columns:repeat(4,1fr);background:linear-gradient(90deg,#10180f,#254121);color:var(--white);padding:34px clamp(18px,4vw,70px)}.trust article{padding:0 28px;border-right:1px solid rgba(255,255,255,.16)}.trust article:first-child{padding-left:0}.trust article:last-child{border-right:0}.trust span{color:var(--gold);font-weight:900;display:block;margin-bottom:12px}.trust strong{display:block;margin-bottom:8px}.trust p{margin:0;color:rgba(255,253,247,.68);line-height:1.5}
.section{max-width:1340px;margin:0 auto;padding:92px clamp(18px,4vw,70px)}.section h2{text-align:center}.section-copy{max-width:740px;text-align:center;margin:-6px auto 46px;color:var(--muted);line-height:1.75}
.service-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:18px}.service-card{overflow:hidden;background:var(--white);box-shadow:0 16px 42px rgba(8,16,7,.11);border:1px solid rgba(8,16,7,.10);transition:transform .25s ease,box-shadow .25s ease}.service-card:hover{transform:translateY(-7px);box-shadow:var(--shadow)}.service-card img{width:100%;height:220px;object-fit:cover;display:block}.service-card div{padding:22px;background:linear-gradient(180deg,#ffffff,#fff8eb)}.service-card h3{font-size:1.13rem;margin-bottom:10px}.service-card p{color:var(--muted);line-height:1.55;font-size:.94rem}.learn{color:var(--gold);font-weight:900}
.vision{display:grid;grid-template-columns:1fr .92fr;gap:60px;padding:96px clamp(18px,5vw,86px);color:var(--white);background:radial-gradient(circle at 80% 20%,rgba(201,154,74,.18),transparent 36%),linear-gradient(120deg,#081007,#263e25)}.vision h2{color:var(--white)}.vision p{color:rgba(255,253,247,.73);line-height:1.75;max-width:720px}.vision-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:32px 0}.vision-steps span{border-top:1px solid rgba(255,255,255,.22);padding-top:16px;color:var(--gold2);font-weight:900;font-size:.86rem}.vision-panel{border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.06);padding:24px;box-shadow:0 24px 80px rgba(0,0,0,.26)}.upload-box{display:grid;place-items:center;text-align:center;min-height:260px;border:1px dashed rgba(255,255,255,.36);background:rgba(255,255,255,.06);margin-bottom:16px;padding:22px}.upload-box strong{color:var(--gold2);font-size:1.35rem}.upload-box p{margin:8px 0 18px}.upload-box input{max-width:240px}.concept-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.concept-grid div{min-height:120px;display:grid;place-items:end start;padding:14px;color:var(--white);font-weight:900;background:linear-gradient(135deg,rgba(201,154,74,.65),rgba(38,62,37,.84)),url('/images/outdoor.jpg') center/cover}
.before-after{display:grid;grid-template-columns:1fr 1fr;box-shadow:var(--shadow);overflow:hidden}.before-after figure{margin:0;position:relative}.before-after img{width:100%;height:500px;object-fit:cover;display:block}.before-after figcaption{position:absolute;top:18px;left:18px;padding:9px 13px;background:rgba(8,16,7,.82);color:var(--white);font-weight:900;text-transform:uppercase;letter-spacing:.1em;font-size:.72rem}
.why{max-width:1280px;margin:0 auto;padding:84px clamp(18px,4vw,70px);display:grid;grid-template-columns:1fr .88fr;gap:60px;align-items:center}.why p{color:var(--muted);line-height:1.75}.why-list{display:grid;gap:14px}.why-list div{background:var(--white);padding:20px 22px;border:1px solid rgba(8,16,7,.10);font-weight:900;box-shadow:0 12px 32px rgba(8,16,7,.06)}.why-list div:before{content:'✓';color:var(--gold);margin-right:10px}
.areas{max-width:1180px;margin:0 auto 90px;padding:74px clamp(18px,4vw,70px);text-align:center;background:linear-gradient(180deg,#fffdf7,#efe0c2);border:1px solid rgba(8,16,7,.11)}.area-grid{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-top:30px}.area-grid span{background:var(--white);border:1px solid rgba(8,16,7,.10);padding:10px 14px;font-weight:800}
.contact{max-width:1280px;margin:0 auto 90px;padding:80px clamp(18px,5vw,80px);display:grid;grid-template-columns:.88fr 1.12fr;gap:58px;background:var(--dark);color:var(--white)}.contact h2{color:var(--white)}.contact p{color:rgba(255,253,247,.72);line-height:1.75}.contact-link{display:block;color:var(--gold2);text-decoration:none;font-weight:900;margin-top:13px}
form{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}label{display:grid;gap:8px;color:rgba(255,253,247,.84);font-weight:800}input,select,textarea{width:100%;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.08);color:var(--white);padding:14px;font:inherit;border-radius:0}option{color:var(--dark)}.full{grid-column:1/-1}
footer{display:grid;grid-template-columns:1.4fr .8fr .8fr;gap:46px;padding:56px clamp(18px,5vw,80px);color:rgba(255,253,247,.75);background:var(--deep)}footer img{width:170px;margin-bottom:18px}footer strong{color:var(--gold2);display:block;margin-bottom:14px;text-transform:uppercase;letter-spacing:.1em;font-size:.78rem}footer a{display:block;text-decoration:none;margin:9px 0;color:rgba(255,253,247,.70)}
@media(max-width:1120px){.service-grid{grid-template-columns:repeat(2,1fr)}.trust{grid-template-columns:repeat(2,1fr)}.vision,.why,.contact,footer{grid-template-columns:1fr}}
@media(max-width:760px){.nav-shell{position:absolute;height:auto;padding-block:14px}.brand span{display:none}nav{gap:12px;font-size:.62rem;flex-wrap:wrap;justify-content:flex-end}.nav-cta{padding:10px 12px}.hero{min-height:780px}h1{font-size:clamp(3.35rem,18vw,5rem)}.trust,.service-grid,.vision-steps,.concept-grid,.before-after,form{grid-template-columns:1fr}.trust article{border-right:0;border-bottom:1px solid rgba(255,255,255,.14);padding:20px 0}.before-after img{height:320px}}
