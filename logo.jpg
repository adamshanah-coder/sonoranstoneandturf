@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap');

:root{
  --dark:#071006;
  --green:#102c16;
  --green2:#193f22;
  --gold:#c99537;
  --gold2:#e1b461;
  --cream:#f7efe2;
  --white:#fffdf7;
  --muted:#d6d1c2;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;background:var(--cream);font-family:Inter,system-ui,sans-serif;color:var(--dark)}
a{text-decoration:none;color:inherit}

.nav{
  position:fixed;top:0;left:0;right:0;z-index:50;height:82px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 clamp(22px,4vw,64px);
  background:rgba(5,13,5,.82);backdrop-filter:blur(18px);
  color:#fff;border-bottom:1px solid rgba(255,255,255,.08)
}
.brand{display:flex;align-items:center;gap:14px}
.brand img{width:58px;height:58px;object-fit:contain}
.brand strong{display:block;letter-spacing:.2em;font-size:1.1rem}
.brand span{display:block;font-size:.78rem;letter-spacing:.22em;color:var(--gold2)}
.nav nav{display:flex;align-items:center;gap:28px;text-transform:uppercase;font-size:.76rem;font-weight:900;letter-spacing:.09em}
.navButton{background:var(--gold);color:#071006;padding:17px 25px}

.hero{position:relative;min-height:820px;display:flex;align-items:center;overflow:hidden;color:#fff}
.heroBg{position:absolute;inset:0;background:url('/images/hero-composition.jpg') center/cover no-repeat;transform:scale(1.02)}
.heroShade{position:absolute;inset:0;background:linear-gradient(90deg,rgba(5,13,5,.86),rgba(5,13,5,.48),rgba(5,13,5,.16)),linear-gradient(180deg,rgba(0,0,0,.15),rgba(0,0,0,.38))}
.heroContent{position:relative;z-index:2;width:min(850px,90vw);padding:130px 0 80px clamp(28px,5vw,68px)}
.eyebrow{color:var(--gold2);font-weight:900;text-transform:uppercase;letter-spacing:.16em;font-size:.78rem;margin:0 0 20px}
h1,h2{font-family:'Playfair Display',Georgia,serif;margin:0;letter-spacing:-.045em}
h1{font-family:Inter,system-ui,sans-serif;font-size:clamp(3.8rem,7vw,7.2rem);line-height:.95;font-weight:900;text-transform:uppercase;letter-spacing:.02em;max-width:850px}
h1 span{color:var(--gold2)}
.lead{font-size:1.18rem;line-height:1.75;color:rgba(255,255,255,.9);max-width:620px;margin:30px 0}
.actions{display:flex;gap:18px;flex-wrap:wrap}
.button{display:inline-flex;gap:18px;align-items:center;justify-content:center;min-height:60px;padding:0 28px;text-transform:uppercase;font-size:.82rem;letter-spacing:.08em;font-weight:900}
.gold{background:var(--gold);color:#071006}.glass{border:1px solid rgba(255,255,255,.55);background:rgba(0,0,0,.18);color:#fff}
.heroTrust{display:flex;gap:36px;flex-wrap:wrap;margin-top:35px;text-transform:uppercase;font-size:.78rem;letter-spacing:.07em}
.heroTrust div{display:grid;gap:4px}.heroTrust span{color:var(--muted)}
.stats{position:absolute;right:42px;bottom:46px;z-index:2;display:grid;grid-template-columns:repeat(4,1fr);background:rgba(8,8,8,.72);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.22);color:#fff;max-width:690px}
.stats div{padding:26px 28px;border-right:1px solid rgba(255,255,255,.16)}.stats div:last-child{border-right:0}.stats strong{display:block;color:var(--gold2);font-size:1.9rem}.stats span{font-size:.82rem;text-transform:uppercase;letter-spacing:.06em}

.consult{display:grid;grid-template-columns:1.3fr 1fr 1fr auto;gap:28px;align-items:center;background:linear-gradient(90deg,#102c16,#071006);color:#fff;padding:32px clamp(24px,4vw,64px)}
.consult strong{display:block;text-transform:uppercase;letter-spacing:.06em}.consult span{display:block;color:#d6d1c2;margin-top:5px}.consult a{background:var(--gold);color:#071006;padding:18px 32px;font-weight:900;text-transform:uppercase}

.services{padding:80px clamp(24px,4vw,64px);text-align:center}
.center{text-align:center}.services h2,.gallery h2,.areas h2,.vision h2,.contact h2{font-family:Inter,system-ui,sans-serif;text-transform:uppercase;letter-spacing:.08em;font-size:clamp(2rem,3vw,3rem);margin-bottom:34px}
.cards{display:grid;grid-template-columns:repeat(7,1fr);gap:18px}
.card{border-radius:8px;overflow:hidden;background:#102c16;color:#fff;text-align:left;box-shadow:0 20px 50px rgba(0,0,0,.18)}
.cardImage{height:190px;background:url('/images/homepage-visual.png') center/cover no-repeat}
.card1 .cardImage{background-position:8% 76%}.card2 .cardImage{background-position:22% 76%}.card3 .cardImage{background-position:36% 76%}.card4 .cardImage{background-position:50% 76%}.card5 .cardImage{background-position:64% 76%}.card6 .cardImage{background-position:78% 76%}.card7 .cardImage{background-position:92% 76%}
.cardBody{position:relative;padding:20px;background:linear-gradient(180deg,#16371d,#071006)}
.cardBody h3{margin:0 0 8px}.cardBody p{margin:0;color:#d6d1c2;line-height:1.45}.cardBody span{position:absolute;right:18px;bottom:18px;color:var(--gold2);font-size:1.6rem}

.vision{display:grid;grid-template-columns:1fr 1fr;gap:40px;padding:90px clamp(24px,5vw,80px);background:#071006;color:#fff}
.vision p{color:#d6d1c2;font-size:1.05rem;line-height:1.7}.vision-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:30px}.vision-steps span{border-top:1px solid rgba(255,255,255,.22);padding-top:15px;color:var(--gold2);font-weight:900}
.vision form,.contact form{display:grid;gap:14px}.vision input,.vision select,.contact input,.contact select,.contact textarea{width:100%;padding:16px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);color:#fff;font:inherit}.vision button,.contact button{border:0;background:var(--gold);padding:18px;font-weight:900;text-transform:uppercase}

.gallery,.areas{padding:80px clamp(24px,5vw,80px);text-align:center}.gallery img{width:100%;max-width:1400px;border-radius:12px;box-shadow:0 30px 80px rgba(0,0,0,.22)}
.areas p:last-child{font-size:1.12rem;color:#5e665d;line-height:1.8;max-width:900px;margin:auto}

.contact{display:grid;grid-template-columns:1fr 1fr;gap:50px;margin:0 clamp(24px,5vw,80px) 80px;padding:70px;background:#102c16;color:#fff}.contact p{color:#d6d1c2;line-height:1.7}.contact a{display:block;color:var(--gold2);font-weight:900;margin-top:12px}.contact textarea{min-height:150px}

@media(max-width:1100px){.cards{grid-template-columns:repeat(2,1fr)}.stats{position:relative;right:auto;bottom:auto;margin:30px clamp(24px,5vw,64px);grid-template-columns:repeat(2,1fr)}.consult,.vision,.contact{grid-template-columns:1fr}}
@media(max-width:760px){.nav{position:absolute;height:auto;align-items:flex-start}.brand div{display:none}.nav nav{gap:10px;font-size:.6rem;flex-wrap:wrap;justify-content:flex-end}.hero{min-height:760px}.heroContent{padding-top:115px}h1{font-size:3.2rem}.cards,.stats,.vision-steps{grid-template-columns:1fr}.consult{grid-template-columns:1fr}.contact{margin:0 18px 60px;padding:32px}}
